<Project>

  <!-- Auto-imported by any Microsoft.Build.Sql project that references this package
       (NuGet imports build/<PackageId>.props at the top of the consumer's build).

       It self-locates the package's restored seed/ folder via $(MSBuildThisFileDirectory)
       and exposes it as the Sencilla_Component_Files SQLCMD variable. Consumers need no
       GeneratePathProperty and no SqlCmdVariable of their own — they just
       :r $(Sencilla_Component_Files)/ApplyData.sql from their post-deployment script. -->

  <!-- Compile this package's schema SOURCE into the consumer's own model, so [dbo].[File]
       and [dbo].[FileStatus] land physically in the consuming dacpac (self-contained). -->
  <ItemGroup>
    <Build Include="$(MSBuildThisFileDirectory)../sql/*.sql" />
  </ItemGroup>

  <!-- Expose this package's seed/ folder as a SQLCMD variable: PackageId with the .Mssql
       suffix dropped and dots replaced by underscores. -->
  <ItemGroup>
    <SqlCmdVariable Include="Sencilla_Component_Files">
      <DefaultValue>$(MSBuildThisFileDirectory)../seed</DefaultValue>
      <Value>$(MSBuildThisFileDirectory)../seed</Value>
    </SqlCmdVariable>
  </ItemGroup>

</Project>
